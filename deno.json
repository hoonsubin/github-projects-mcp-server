{
  "tasks": {
    "dev": "deno run --env-file --watch --allow-env --allow-net --allow-read src/index.ts",
    "start": "deno run --allow-env --allow-net --allow-read src/index.ts",
    "inspector": "deno run --allow-env --allow-net --allow-read --allow-run src/index.ts"
  },
  "imports": {
    "@modelcontextprotocol/inspector": "npm:@modelcontextprotocol/inspector@^0.21.2",
    "@modelcontextprotocol/sdk": "npm:@modelcontextprotocol/sdk@^1.29.0",
    "express": "npm:express@^5.2.1",
    "zod": "npm:zod@^3.23.8",
    "@std/assert": "jsr:@std/assert@1"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "lib": [
      "ES2022",
      "deno.ns",
      "deno.window"
    ],
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "include": [
        "no-unused-vars",
        "no-explicit-any",
        "eqeqeq"
      ]
    }
  }
}