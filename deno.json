{
  "tasks": {
    "dev": "deno run --watch --allow-env --allow-net src/index.ts",
    "start": "deno run --allow-env --allow-net src/index.ts",
    "compile": "deno compile --allow-env --allow-net --output github-projects-mcp src/index.ts",
    "check": "deno check src/index.ts",
    "inspector": "deno run --allow-env --allow-net npm:@modelcontextprotocol/inspector src/index.ts"
  },
  "imports": {
    "@modelcontextprotocol/inspector": "npm:@modelcontextprotocol/inspector@^0.21.2",
    "@modelcontextprotocol/sdk": "npm:@modelcontextprotocol/sdk@^1.29.0",
    "zod": "npm:zod@^3.23.8",
    "@std/assert": "jsr:@std/assert@1"
  },
  "compilerOptions": {
    "lib": ["ES2022", "deno.ns", "deno.window"],
    "strict": true
  }
}
